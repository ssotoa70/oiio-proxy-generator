FROM oiio-proxy-generator:latest

ENV LD_LIBRARY_PATH="/layers/paketo-buildpacks_cpython/cpython/lib:/layers/apt-buildpack/apt/lib/x86_64-linux-gnu:/layers/apt-buildpack/apt/usr/lib/x86_64-linux-gnu"
ENV PATH="/layers/paketo-buildpacks_cpython/cpython/bin:${PATH}"
ENV PYTHONPATH="/workspace:/layers/paketo-buildpacks_cpython/cpython/lib/python3.12/site-packages:/layers/paketo-buildpacks_pip-install/packages/lib/python3.12/site-packages"

# OCIO config path (ACES 1.3 from system package)
ENV OCIO="/usr/share/color/opencolorio/aces_1.3/config.ocio"
ENV OCIO_CONFIG_PATH="/usr/share/color/opencolorio/aces_1.3/config.ocio"

WORKDIR /workspace

# Bypass the CNB launcher -- start the VAST runtime directly with Python
ENTRYPOINT ["python3", "-m", "vast_runtime.main"]
CMD ["--app-path", "/workspace", "--handler", "main.py"]
